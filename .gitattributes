# Normalize line endings to LF on commit
* text=auto eol=lf

# Source files
*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf

# Binaries — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.dll   binary
*.exe   binary
